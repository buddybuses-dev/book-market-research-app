      ]
    },
    {
      "parameters": {
        "functionCode": "const now = new Date();\nreturn [{ json: { execution_id: `exec_${now.getFullYear()}${String(now.getMonth()+1).padStart(2,'0')}${String(now.getDate()).padStart(2,'0')}`, workflow_name: 'Book Outline Generator', timestamp: now.toISOString() } }];"
      },
      "id": "ctx",
