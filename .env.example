# Trigger rebuild — Railway port fix
# ═══════════════════════════════════════════════════════════════
# Book Market Research App — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── LIVE DATA APIs ──────────────────────────────────────────────
# SerpApi — Amazon search + Google Trends (https://serpapi.com)
SERPAPI_API_KEY=your_serpapi_key_here

# DataForSEO — Keyword volume + difficulty (https://dataforseo.com)
# Format: base64(login:password)
DATAFORSEO_CREDENTIALS=your_base64_credentials_here

# ── IMAGE GENERATION ─────────────────────────────────────────────
# Google Gemini / Nano Banana — Book covers, illustrations, pages
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── TTS / AUDIOBOOK ──────────────────────────────────────────────
# ElevenLabs — Text-to-speech (https://elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ── AI FALLBACK (free) ───────────────────────────────────────────
# Solene — Base44 AI agent for keyword ideas, market summaries
# Get key: Settings → Developer / API Docs in your agent
SOLENE_API_KEY=your_solene_api_key_here

# ── OPTIONAL: LLM fallback (if Solene unavailable) ────────────────
# Anthropic — Claude for research fallback
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── APP SECURITY ────────────────────────────────────────────────
# Secret to protect API endpoints
APP_SECRET=your_app_secret_here
