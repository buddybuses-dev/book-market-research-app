# ============================================================
# REQUIRED — Solene Agent API Key (powers ALL research tools)
# ============================================================
# 1. Open https://app.base44.com/superagent/6a5ff38fd72457c0ed1c8ddd
# 2. Click Settings (gear icon) → Developer / API Docs
# 3. Copy your API key
SOLENE_API_KEY=your_solene_agent_api_key_here

# ============================================================
# OPTIONAL — Direct Anthropic fallback (if Solene is unavailable)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================================
# OPTIONAL — n8n automation
# ============================================================
N8N_WEBHOOK_URL=your_n8n_webhook_url
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_SECRET_MODE=header
N8N_WEBHOOK_SECRET_HEADER_NAME=X-N8N-SECRET
N8N_WEBHOOK_SECRET_QUERY_PARAM_NAME=secret

# ============================================================
# OPTIONAL — API security
# ============================================================
APP_API_SECRET=
NEXT_PUBLIC_APP_API_SECRET=

# ============================================================
# OPTIONAL — Paid connectors (Solene fallback runs if not set)
# ============================================================
SERPAPI_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
AMAZON_SP_API_WEBHOOK_URL=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=CwhRBWXzGAHq8TQ4Fs17
KEYWORDS_EVERYWHERE_API_KEY=
SCRAPINGBEE_API_KEY=
SE_RANKING_API_KEY=
SEMRUSH_API_KEY=
HALOSCAN_API_KEY=
SCRAPE_IT_CLOUD_API_KEY=

# ============================================================
# Public flags — set "true" if provider is configured
# ============================================================
NEXT_PUBLIC_SERPAPI_CONFIGURED=false
NEXT_PUBLIC_DATAFORSEO_CONFIGURED=false
NEXT_PUBLIC_KW_EVERYWHERE_CONFIGURED=false
NEXT_PUBLIC_SCRAPINGBEE_CONFIGURED=false
NEXT_PUBLIC_ELEVENLABS_CONFIGURED=false
NEXT_PUBLIC_AMAZON_CONFIGURED=false
