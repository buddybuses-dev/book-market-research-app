# ============================================================
# TIER 1 — Live data (best results)
# ============================================================
SERPAPI_API_KEY=            # Amazon search, Google Trends — real live data
ELEVENLABS_API_KEY=         # Audiobook TTS voiceovers
ELEVENLABS_VOICE_ID=CwhRBWXzGAHq8TQ4Fs17

# ============================================================
# TIER 2 — Solene AI agent (free, routes through Base44)
# ============================================================
# Get from: app.base44.com → Settings → Developer / API Docs
SOLENE_API_KEY=             # Powers all tools when paid APIs are absent

# ============================================================
# TIER 3 — Direct Anthropic fallback (last resort)
# ============================================================
ANTHROPIC_API_KEY=          # Only needed if Solene is also unavailable

# ============================================================
# OPTIONAL — n8n automation
# ============================================================
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_SECRET_MODE=header
N8N_WEBHOOK_SECRET_HEADER_NAME=X-N8N-SECRET

# ============================================================
# OPTIONAL — API security
# ============================================================
APP_API_SECRET=
NEXT_PUBLIC_APP_API_SECRET=

# ============================================================
# OPTIONAL — Other paid connectors
# ============================================================
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
KEYWORDS_EVERYWHERE_API_KEY=
SCRAPINGBEE_API_KEY=
SE_RANKING_API_KEY=
SEMRUSH_API_KEY=
HALOSCAN_API_KEY=
SCRAPE_IT_CLOUD_API_KEY=
AMAZON_SP_API_WEBHOOK_URL=

# ============================================================
# Public flags — set "true" if provider is configured
# ============================================================
NEXT_PUBLIC_SERPAPI_CONFIGURED=true
NEXT_PUBLIC_ELEVENLABS_CONFIGURED=true
NEXT_PUBLIC_DATAFORSEO_CONFIGURED=false
NEXT_PUBLIC_KW_EVERYWHERE_CONFIGURED=false
NEXT_PUBLIC_SCRAPINGBEE_CONFIGURED=false
NEXT_PUBLIC_AMAZON_CONFIGURED=false
