# Required API Keys
SERPAPI_API_KEY=your_serpapi_key
N8N_WEBHOOK_URL=your_n8n_webhook_url
AMAZON_SP_API_WEBHOOK_URL=your_amazon_bridge_webhook_url

# Optional: n8n webhook authentication
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_SECRET_MODE=header
N8N_WEBHOOK_SECRET_HEADER_NAME=X-N8N-SECRET
N8N_WEBHOOK_SECRET_QUERY_PARAM_NAME=secret

# Optional: DataForSEO
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Optional: Keywords Everywhere
KEYWORDS_EVERYWHERE_API_KEY=

# Optional: ScrapingBee
SCRAPINGBEE_API_KEY=

# Optional: Crayo
CRAYO_API_KEY=

# Optional: ElevenLabs (for audiobook voiceovers)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=CwhRBWXzGAHq8TQ4Fs17

# Optional: Other providers
SE_RANKING_API_KEY=
SEMRUSH_API_KEY=
HALOSCAN_API_KEY=
SCRAPE_IT_CLOUD_API_KEY=
MAGIC_MEAL_KITS_API_KEY=

# Public environment flags (set to 'true' if provider is configured)
NEXT_PUBLIC_SERPAPI_CONFIGURED=true
NEXT_PUBLIC_DATAFORSEO_CONFIGURED=true
NEXT_PUBLIC_KW_EVERYWHERE_CONFIGURED=true
NEXT_PUBLIC_SCRAPINGBEE_CONFIGURED=true
NEXT_PUBLIC_CRAYO_CONFIGURED=true
NEXT_PUBLIC_ELEVENLABS_CONFIGURED=true
NEXT_PUBLIC_AMAZON_CONFIGURED=true
