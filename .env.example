# ============================================================
# REQUIRED — Claude AI (free research fallback for all tools)
# ============================================================
# Get your key at https://console.anthropic.com
# This powers ALL market research, keywords, trends, and
# Amazon pricing analysis when paid APIs are not configured.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================================
# OPTIONAL — n8n automation
# ============================================================
N8N_WEBHOOK_URL=your_n8n_webhook_url
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_SECRET_MODE=header
N8N_WEBHOOK_SECRET_HEADER_NAME=X-N8N-SECRET
N8N_WEBHOOK_SECRET_QUERY_PARAM_NAME=secret

# ============================================================
# OPTIONAL — API security
# ============================================================
# Protects /api/tool-run and /api/trends from unauthenticated callers.
# Callers must send this value in the "X-App-Secret" header.
# Leave empty to keep routes open (default).
APP_API_SECRET=
NEXT_PUBLIC_APP_API_SECRET=

# ============================================================
# OPTIONAL — Paid connectors (Claude fallback runs if not set)
# ============================================================

# SerpApi — Google Trends, Amazon search, Autocomplete
SERPAPI_API_KEY=

# DataForSEO — Keyword search volume
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Amazon SP-API bridge (your own n8n/webhook endpoint)
AMAZON_SP_API_WEBHOOK_URL=

# ElevenLabs — Audiobook TTS voiceovers
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=CwhRBWXzGAHq8TQ4Fs17

# Other providers (fully optional)
KEYWORDS_EVERYWHERE_API_KEY=
SCRAPINGBEE_API_KEY=
SE_RANKING_API_KEY=
SEMRUSH_API_KEY=
HALOSCAN_API_KEY=
SCRAPE_IT_CLOUD_API_KEY=

# ============================================================
# Public flags — set to "true" if provider is configured
# ============================================================
NEXT_PUBLIC_SERPAPI_CONFIGURED=false
NEXT_PUBLIC_DATAFORSEO_CONFIGURED=false
NEXT_PUBLIC_KW_EVERYWHERE_CONFIGURED=false
NEXT_PUBLIC_SCRAPINGBEE_CONFIGURED=false
NEXT_PUBLIC_ELEVENLABS_CONFIGURED=false
NEXT_PUBLIC_AMAZON_CONFIGURED=false
